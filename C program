#include <stdio.h>

int quiz_numbers(int answer, int redos, char question[], int answers[], int len) {
    printf("%s\n", question);

    int i=1;

    while (i<=len) {
        printf("%d:%d\n", i, answers[i-1]);
        i=i+1;
    }

    int num=0;

    while (redos>=0) {
        printf("Write the answer\n");
        scanf("%d", &num);

        while (num>len) {
            printf("Write the answer choose from the numbers: 1...%d\n", len);
            scanf("%d", &num);
        }


        if (num==answer) {
            printf("Correct\n");
            redos=-1;

        }
        else {
            if (redos>0) {
                printf("Again\n");
            }
            else {
                printf("The answer was %d", answer);
            }

                redos=redos-1;
            }
    }

    return 0;
}








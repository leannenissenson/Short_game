int assign_string(int index, char array[5][16], char string[], int len, int size_string) {

    int i=0;

    while (i<len) {
        if (i<=size_string) {
            array[index][i]=string[i];
        }

        else {
            array[index][i]=' ';
        }

        i=i+1;
    }

    return 0;
}

int strlen(const char string[]) {
    size_t n =0;

    while ( string[n] != '\0' ) ++n;

    return n;
}

int assign_strings(char string[], char string2[], char string3[], char string4[], char string5[], char array[5][16]) {
    assign_string(0, array, string, 16, strlen(string));

